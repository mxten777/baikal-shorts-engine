# 백엔드 환경 변수 예시
# 이 파일을 복사: cp .env.example .env

# ─── 앱 설정 ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your_super_secret_key
PEXELS_API_KEY=vMawSUXeTxBU2rTAPtrvYt2UPsMgjjuSPQaJa6qXAe5Ri0S95KLGnnhA

# ─── 브랜드 / 채널 연락처 ───────────────────────────────────
# YouTube 캡션, 썸네일 폴백 텍스트 등에 사용됨
BRAND_NAME=바이칼시스템즈
BRAND_EMAIL=contact@baikalsystems.com
BRAND_WEBSITE=www.baikalsystems.com
DEFAULT_HASHTAGS=["바이칼시스템즈","IT컨설팅"]

# ─── Supabase ───────────────────────────────────────────────
# Supabase Dashboard > Settings > API 에서 확인
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=shorts-engine

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
TTS_VOICE=nova

# ─── YouTube (선택적) ────────────────────────────────────────
# Google Cloud Console > OAuth2 클라이언트 ID
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/auth/youtube/callback

# ─── Instagram (선택적) ─────────────────────────────────────
# Meta Developers > Instagram Graph API
# OAuth를 통해 액세스 토큰 발급
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:5173/auth/instagram/callback

# ─── 에러 트래킹 ─────────────────────────────────────────────
# Sentry DSN (프로덕션에서만 필수)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── CORS ───────────────────────────────────────────────────
# 프론트엔드 URL (JSON 배열 형식)
# development: localhost만, production: 실제 도메인만 허용
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# ─── FFmpeg ─────────────────────────────────────────────────
# PATH에 있으면 "ffmpeg", 아니면 절대경로
# Windows: C:/ffmpeg/bin/ffmpeg.exe
# Linux/Mac: /usr/bin/ffmpeg
FFMPEG_PATH=ffmpeg
